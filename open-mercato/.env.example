# Public URL (set to the app's https domain on Miget).
APP_URL=http://localhost:5000

JWT_SECRET=                     # openssl rand -hex 32
MEILISEARCH_MASTER_KEY=         # openssl rand -base64 24
TENANT_DATA_ENCRYPTION_KEY=     # openssl rand -hex 16  (32 chars)

# Superadmin created on first init.
OM_INIT_SUPERADMIN_EMAIL=admin@example.com
OM_INIT_SUPERADMIN_PASSWORD=
