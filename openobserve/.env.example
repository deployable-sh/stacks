# Root account (created on first start).
ZO_ROOT_USER_EMAIL=admin@example.com
ZO_ROOT_USER_PASSWORD=

# Storage: "disk" (default, uses the volume) or "s3" (Miget Buckets).
# For S3, set ZO_LOCAL_MODE_STORAGE=s3 and fill the rest:
ZO_LOCAL_MODE_STORAGE=disk
ZO_S3_PROVIDER=s3
ZO_S3_SERVER_URL=https://s3.eu-east-1.miget.io
ZO_S3_REGION_NAME=us-east-1
ZO_S3_ACCESS_KEY=
ZO_S3_SECRET_KEY=
ZO_S3_BUCKET_NAME=openobserve
