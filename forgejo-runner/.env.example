# Your Forgejo instance (in-project: http://forgejo:5000) or Codeberg.
FORGEJO_URL=https://codeberg.org

# From the runner you create in the UI: Settings > Actions > Runners.
RUNNER_UUID=
RUNNER_TOKEN=

# Jobs target this via runs-on. host = shell in this container.
RUNNER_LABELS=miget:host
RUNNER_CAPACITY=1
