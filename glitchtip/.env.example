# Copy to .env for local `docker compose up`.
# SECRET_KEY signs Django sessions, generate with: openssl rand -hex 32
# On Miget it is the stack's only required variable.
SECRET_KEY=local-dev-only-change-me
# Public URL; set to the web app's https domain on Miget (after first deploy).
GLITCHTIP_DOMAIN=http://localhost:5000
