# Session secret. Generate with:  openssl rand -base64 36
NEXTAUTH_SECRET=

# The app's public URL (https domain on Miget).
NEXTAUTH_URL=http://localhost:5000

# Meilisearch master key - must be identical on the app and Meilisearch.
# Generate with:  openssl rand -base64 36
MEILI_MASTER_KEY=

# Optional AI auto-tagging. Set ONE: an OpenAI key, or an Ollama/LiteLLM
# base URL (e.g. http://ollama:5000 if you also run the ollama template).
OPENAI_API_KEY=
OLLAMA_BASE_URL=
