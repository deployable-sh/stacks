# Copy to .env for local `docker compose up`.
#
# N8N_ENCRYPTION_KEY encrypts stored credentials; it must be identical on
# the main instance and all workers, and must NEVER change once set (n8n
# can't decrypt existing credentials with a new key). Generate with:
#   openssl rand -hex 24
# On Miget this is the stack's only required variable.
N8N_ENCRYPTION_KEY=local-dev-only-change-me
