# Rails secret - a long random string. Generate with:
#   openssl rand -hex 64
SECRET_KEY_BASE=

# The app's public URL (https domain on Miget).
BASE_URL=http://localhost:5000

# Optional: email for invites and notifications.
MAILER_FROM_ADDRESS=
SMTP_ADDRESS=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# Optional: Web Push (browser notifications). Generate a VAPID keypair
# with any web-push tool, e.g.  npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
