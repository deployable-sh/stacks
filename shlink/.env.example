# The short domain Shlink generates links on (its https domain on Miget,
# e.g. links.example.com). Locally this is fine as localhost:5000.
DEFAULT_DOMAIN=localhost:5000
IS_HTTPS_ENABLED=false

# Your first API key, created on startup. Use a long random string:
#   openssl rand -hex 16
INITIAL_API_KEY=

# Optional: a MaxMind GeoLite2 license key enables geographic visit stats.
GEOLITE_LICENSE_KEY=
