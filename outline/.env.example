URL=http://localhost:5000
SECRET_KEY=     # openssl rand -hex 32
UTILS_SECRET=   # openssl rand -hex 32
REDIS_AUTH=     # openssl rand -hex 24

# A Miget Bucket (private visibility) - uploads/avatars live here, which
# makes the app container stateless.
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
S3_BUCKET_URL=https://s3.eu-east-1.miget.io
S3_BUCKET_NAME=outline-uploads

# Magic-link login emails (mailpit for testing).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=wiki@example.com
