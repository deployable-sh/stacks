# Copy to .env for local `docker compose up`.
SECRET_KEY=local-dev-only-change-me-0123456789abcdef0123456789abcdef  # openssl rand -hex 32 (must be >=50 chars; Bugsink's deploy check rejects shorter)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me                   # first-login superuser
BASE_URL=http://localhost:5000             # the app's https domain on Miget
