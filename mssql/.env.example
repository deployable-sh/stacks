# Setting Y accepts the Microsoft SQL Server EULA.
ACCEPT_EULA=Y

# sa password: min 8 chars, 3 of 4 classes (upper/lower/digit/symbol).
MSSQL_SA_PASSWORD=

# Express has a free production license (50 GB/db, 1.4 GB buffer pool,
# 4 cores). Standard/Enterprise are BYOL - set only if you hold a license.
MSSQL_PID=Express
