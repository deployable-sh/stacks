# Rails secret - a long random string. Generate with:
#   openssl rand -hex 64
SECRET_KEY_BASE=

# Password for the PostGIS database (used by the app and the db service).
DB_PASSWORD=dawarich-local-only

# Rails host allowlist - MUST include the app's domain or requests are
# blocked. Comma-separated. On Miget set this to your app's https host.
APPLICATION_HOSTS=localhost
APPLICATION_PROTOCOL=http

# Default time zone for the UI.
TIME_ZONE=UTC
