# Local development values, copy to .env for `docker compose up`.
# On Miget the KONG_PG_* values are auto-wired from the managed Postgres
# (compose.miget.yaml); only the ADMIN_* pair must be set on the stack.
KONG_PG_HOST=db
KONG_PG_USER=kong
KONG_PG_PASSWORD=kong-local-only
KONG_PG_DATABASE=kong

# Basic-auth credentials for Kong Manager (the `admin` service). On Miget
# only ADMIN_PASSWORD is prompted (pre-filled with a strong random secret);
# the username defaults to "admin".
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
