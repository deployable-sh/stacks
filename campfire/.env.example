# Rails secret - a long random string. Generate with:
#   openssl rand -hex 64
SECRET_KEY_BASE=

# Optional: Web Push (browser/mobile notifications). Auto-generated on
# first boot if left blank; set a fixed pair to keep it stable across
# redeploys. Generate with:  npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Optional: error reporting.
SENTRY_DSN=
