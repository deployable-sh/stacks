NEXTAUTH_SECRET=                        # openssl rand -base64 32
NEXT_PRIVATE_ENCRYPTION_KEY=            # openssl rand -hex 16 (32+ chars)
NEXT_PRIVATE_ENCRYPTION_SECONDARY_KEY=  # openssl rand -hex 16

# Public URL (the app's https domain on Miget; runtime-injected).
NEXT_PUBLIC_WEBAPP_URL=http://localhost:5000

# PKCS#12 signing certificate as base64. Self-signed is fine:
#   openssl genrsa -out private.key 2048
#   openssl req -new -x509 -key private.key -out certificate.crt -days 365
#   openssl pkcs12 -export -out cert.p12 -inkey private.key -in certificate.crt -legacy
#   base64 -i cert.p12 | tr -d '\n'
SIGNING_CERT_B64=
SIGNING_PASSPHRASE=

# Signing emails (mailpit:1025 for testing).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_NAME=Documenso
SMTP_FROM_ADDRESS=sign@example.com
