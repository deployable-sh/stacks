PENPOT_SECRET_KEY=      # openssl rand -base64 64 | tr -d '\n'
REDIS_AUTH=             # openssl rand -hex 24

# The app's public URL (https domain on Miget).
PENPOT_PUBLIC_URI=http://localhost:5000

# Recommended on Miget: store assets in a Bucket and drop the RWX volume.
#   PENPOT_OBJECTS_STORAGE_BACKEND=s3
PENPOT_OBJECTS_STORAGE_BACKEND=fs
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
S3_BUCKET_NAME=penpot-assets
S3_ENDPOINT=https://s3.eu-east-1.miget.io
