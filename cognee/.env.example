# The only hard requirement - LLM access for fact extraction.
LLM_API_KEY=

# OpenAI default; or route through the litellm template:
#   LLM_PROVIDER=custom
#   LLM_ENDPOINT=http://litellm:5000/v1
#   LLM_MODEL=openai/<model-name-in-litellm>
LLM_PROVIDER=openai
LLM_MODEL=openai/gpt-4o-mini
LLM_ENDPOINT=
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=openai/text-embedding-3-large
EMBEDDING_ENDPOINT=

# Override the insecure default.
FASTAPI_USERS_JWT_SECRET=   # openssl rand -hex 32
