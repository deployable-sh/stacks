# Basic-auth credentials. Without these the registry runs OPEN - always
# set a password before exposing it publicly.
REGISTRY_AUTH_USER=admin
REGISTRY_AUTH_PASSWORD=
REGISTRY_AUTH_REALM=Registry

# Storage. Leave empty to use the local filesystem volume; fill the block
# to store images in a Miget Bucket (recommended - keeps the app
# stateless). REGIONENDPOINT is the Bucket's S3 endpoint host.
REGISTRY_STORAGE_S3_REGION=auto
REGISTRY_STORAGE_S3_REGIONENDPOINT=
REGISTRY_STORAGE_S3_BUCKET=
REGISTRY_STORAGE_S3_ACCESSKEY=
REGISTRY_STORAGE_S3_SECRETKEY=
REGISTRY_STORAGE_S3_FORCEPATHSTYLE=true
