# The app's public URL (https domain on Miget).
NEXT_PUBLIC_WEBAPP_URL=http://localhost:5000
NEXTAUTH_URL=http://localhost:5000/api/auth

# NextAuth session secret. Generate with:  openssl rand -base64 32
NEXTAUTH_SECRET=

# AES-256 encryption key (exactly 32 bytes). Generate with:
#   openssl rand -base64 24
CALENDSO_ENCRYPTION_KEY=
