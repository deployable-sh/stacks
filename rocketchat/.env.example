# The app's public URL (https domain on Miget).
ROOT_URL=http://localhost:5000

# MongoDB replica set. Locally the bundled single-node set is used;
# on Miget point at the `mongodb` template:
#   mongodb://mongo-1:27017,mongo-2:27017,mongo-3:27017/rocketchat?replicaSet=rs0
MONGO_URL=mongodb://mongo:27017/rocketchat?replicaSet=rs0
