# The app's public URL (https domain on Miget). Must match exactly, no
# trailing slash - a wrong value breaks CSS, links, and redirects.
APP_URL=http://localhost:5000

# Laravel app key. Generate (keep the `base64:` prefix):
#   docker run -it --rm --entrypoint /usr/bin/php \
#     lscr.io/linuxserver/bookstack:26.05.1 artisan key:generate --show
APP_KEY=
