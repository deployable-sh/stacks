# Fine-grained or classic PAT. Classic scopes: `repo` (repo runners) or
# `admin:org` (org runners). Used to mint registration tokens.
ACCESS_TOKEN=

# repo | org
RUNNER_SCOPE=repo
# For repo scope:
REPO_URL=https://github.com/you/your-repo
# For org scope (set RUNNER_SCOPE=org and leave REPO_URL empty):
ORG_NAME=

LABELS=self-hosted,linux,x64,miget
# true = runner deregisters after each job (clean-slate; pairs with replicas)
EPHEMERAL=false
