# Alphanumeric only: head /dev/urandom | tr -dc A-Za-z0-9 | head -c 63
SECRET_KEY_BASE=

REDIS_AUTH=     # openssl rand -hex 24

# The app's public URL (https domain on Miget).
FRONTEND_URL=http://localhost:5000

# Leave true for onboarding; set false once your team is in.
ENABLE_ACCOUNT_SIGNUP=true

# Agent notifications + transactional email (mailpit for testing).
MAILER_SENDER_EMAIL=Chatwoot <support@example.com>
SMTP_ADDRESS=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
