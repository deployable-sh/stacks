# The app's public URL (https domain on Miget).
APP_URL=http://localhost:5000

# Long random string - signs sessions and tokens. Generate with:
#   openssl rand -hex 32
APP_SECRET=

# Attachment storage. Local volume by default; set to s3 and fill the
# AWS_S3_* block to use a Miget Bucket (recommended on Miget).
STORAGE_DRIVER=local
AWS_S3_ENDPOINT=
AWS_S3_REGION=auto
AWS_S3_BUCKET=
AWS_S3_ACCESS_KEY_ID=
AWS_S3_SECRET_ACCESS_KEY=
AWS_S3_FORCE_PATH_STYLE=true
