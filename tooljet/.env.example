# Public URL of the instance (scheme required).
TOOLJET_HOST=http://localhost:5000

# Session cookies.
SECRET_KEY_BASE=        # openssl rand -hex 64

# Datasource credential encryption - losing it orphans saved datasources.
LOCKBOX_MASTER_KEY=     # openssl rand -hex 32

# ToolJet Database (PostgREST) JWT.
PGRST_JWT_SECRET=       # openssl rand -hex 32
