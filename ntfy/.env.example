# The app's public URL (https domain on Miget) - links/attachments embed it.
NTFY_BASE_URL=http://localhost:5000

# Declarative users: name:bcrypt:role (comma-separated). Generate hash:
#   docker run --rm -it binwiederhier/ntfy user hash
# In .env keep the $ signs literal; in compose they are escaped as $$.
NTFY_AUTH_USERS=
