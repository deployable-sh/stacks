# Public URL (the app's https domain on Miget).
NEXTAUTH_URL=http://localhost:5000
NEXTAUTH_SECRET=        # openssl rand -base64 32
REDIS_AUTH=             # openssl rand -hex 24

# AWS SES credentials - useSend delivers through YOUR SES.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# GitHub OAuth app (login provider) - callback: <NEXTAUTH_URL>/api/auth/callback/github
GITHUB_ID=
GITHUB_SECRET=
