# The shop's domain - BAKED INTO THE DATABASE at install time. Set the
# final domain before the first boot (locally keep localhost:5000).
PS_DOMAIN=localhost:5000
PS_ENABLE_SSL=0          # 1 on Miget (TLS terminates at the ingress)

# Back-office login (at /admin).
ADMIN_MAIL=admin@example.com
ADMIN_PASSWD=

PS_LANGUAGE=en
PS_COUNTRY=US
