# The app's public URL (https domain on Miget).
WEB_URL=http://localhost:5000
CORS_ALLOWED_ORIGINS=http://localhost:5000

# Django secret - a long random string. Generate with:
#   openssl rand -hex 32
SECRET_KEY=

# In-stack MinIO credentials + bucket (file storage).
MINIO_ROOT_USER=minio-access
MINIO_ROOT_PASSWORD=minio-secret-local-only
MINIO_BUCKET=uploads

# RabbitMQ password (Miget only - must match AMQP_URL in compose.miget.yaml).
RABBITMQ_PASSWORD=plane-local-only

# Optional S3 region label (leave blank for MinIO).
AWS_REGION=
