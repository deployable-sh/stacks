# EXACTLY 32 characters, identical on both apps:
#   openssl rand -base64 24 | tr -d '\n'
ENCRYPTION_SECRET=

# This account gets the unlimited plan in your instance.
ADMIN_EMAIL=admin@example.com

# Public URLs (the two apps' https domains on Miget).
NEXTAUTH_URL=http://localhost:5000
NEXT_PUBLIC_VIEWER_URL=http://localhost:5001

# Magic-link login emails (mailpit works for testing).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
NEXT_PUBLIC_SMTP_FROM='Typebot' <typebot@example.com>

# Set true after your team has signed up.
DISABLE_SIGNUP=false
