PAPERLESS_SECRET_KEY=       # openssl rand -base64 42
REDIS_AUTH=                 # openssl rand -hex 24

# First-run admin (idempotent superuser).
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=

# The app's public URL (https domain on Miget).
PAPERLESS_URL=http://localhost:5000

# ISO 639-2 OCR language(s), e.g. eng, deu, eng+deu. Extra packs install
# at boot via PAPERLESS_OCR_LANGUAGES.
PAPERLESS_OCR_LANGUAGE=eng
PAPERLESS_TIME_ZONE=Etc/UTC
