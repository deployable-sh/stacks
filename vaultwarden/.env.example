# Full public URL of the instance (https in production - WebAuthn and
# email links depend on it).
DOMAIN=http://localhost:5000

# Close after creating your accounts (org invitations still work).
SIGNUPS_ALLOWED=true

# Optional admin page token - argon2 PHC hash, NOT plaintext:
#   docker run --rm -it vaultwarden/server /vaultwarden hash --preset owasp
# In .env files, keep the hash single-quoted; in compose, escape $ as $$.
ADMIN_TOKEN=
